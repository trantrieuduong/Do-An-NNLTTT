@startuml ModerationSequenceDiagram
skinparam maxMessageSize 150
title Sequence Diagram: AI Content Moderation

actor "System Cron" as Cron
participant "ModerationJob\nScheduler" as Scheduler
database "ModerationJob\nRepository" as JobRepo
participant "ModerationJob\nExecutor" as Executor
participant "Moderation\nOrchestrator" as Orchestrator
participant "Moderation\nService" as ModService
participant "S3Service &\nFFmpeg" as S3
participant "OpenAI API" as OpenAI
database "Post/Comment\nRepository" as TargetRepo
participant "Notification\nService" as NotifService 

Cron -> Scheduler : processPendingJobs() (mỗi 30s)
activate Scheduler

Scheduler -> JobRepo : findJobsForProcessing()
JobRepo --> Scheduler : List<ModerationJob> (PENDING)

loop cho mỗi job
    Scheduler -> Executor : prepareAndExecute(jobId)
    activate Executor
    
    Executor -> JobRepo : Đánh dấu PROCESSING & tăng retryCount
    
    Executor -> Executor : execute(jobId) (@Retryable)
    activate Executor
    
    Executor -> JobRepo : findById(jobId)
    JobRepo --> Executor : job details (POST/COMMENT)
    
    alt TargetType == POST
        Executor -> Orchestrator : processPost(job)
        activate Orchestrator
        
        Orchestrator -> TargetRepo : findById(postId)
        TargetRepo --> Orchestrator : Post data
        
        opt Post chứa Text
            Orchestrator -> ModService : moderateText(post.getContent())
            ModService -> OpenAI : Gửi request kiểm duyệt Text
            OpenAI --> ModService : Trả về ModerationVerdict
            ModService --> Orchestrator : ModerationVerdict
            Orchestrator -> JobRepo : Lưu ModerationResult
        end
        
        opt Có Media (Image) và chưa bị BLOCK
            Orchestrator -> ModService : moderateImageUrl(imageUrl)
            ModService -> OpenAI : Gửi kiểm duyệt Image URL
            OpenAI --> ModService : Trả về ModerationVerdict
            ModService --> Orchestrator : ModerationVerdict
            Orchestrator -> JobRepo : Lưu ModerationResult
        end
        
        opt Có Media (Video) và chưa bị BLOCK
            Orchestrator -> ModService : moderateVideoUrl(videoUrl)
            activate ModService
            ModService -> S3 : Download video tạm & trích xuất frames qua FFmpeg
            ModService -> OpenAI : Gửi từng URL của Frame lên OpenAI API
            OpenAI --> ModService : Trả kết quả đánh giá Frames
            ModService -> S3 : Xóa dữ liệu tạm / file rác
            ModService --> Orchestrator : List<ModerationVerdict>
            deactivate ModService
            Orchestrator -> JobRepo : Lưu ModerationResult
        end
        
        Orchestrator -> Orchestrator : Đánh giá chung (REJECTED/UNDER_REVIEW/PUBLISHED)
        Orchestrator -> TargetRepo : save(post.setStatus(...))
        
        opt Status là REJECTED hoặc UNDER_REVIEW
            Orchestrator -> NotifService : sendNotification(violatedPost)
        end
        
        Orchestrator --> Executor : Xong
        deactivate Orchestrator
        
    else TargetType == COMMENT
        Executor -> Orchestrator : processComment(job)
        activate Orchestrator
        
        Orchestrator -> TargetRepo : findById(commentId)
        TargetRepo --> Orchestrator : Comment data
        
        Orchestrator -> ModService : moderateText(comment)
        ModService -> OpenAI : Gửi Text kiểm duyệt
        OpenAI --> ModService : Trả kết quả Text
        ModService --> Orchestrator : ModerationVerdict
        Orchestrator -> JobRepo : Lưu ModerationResult
        
        opt Kết quả BLOCK
            Orchestrator -> NotifService : sendNotification(violatedComment)
            Orchestrator -> TargetRepo : delete(comment)
        end
        
        Orchestrator --> Executor : Xong
        deactivate Orchestrator
    end
    
    Executor -> JobRepo : Đánh dấu trạng thái Job thành DONE
    
    == Xử lý lỗi ==
    opt Lỗi quá 3 lần gọi API
        Executor -> Executor : recover(Exception)
        Executor -> JobRepo : Đổi trạng thái Job thành FAILED (hoặc PENDING)
    end
        
    deactivate Executor
    deactivate Executor
end

Scheduler --> Cron : Hoàn thành
deactivate Scheduler
@enduml
