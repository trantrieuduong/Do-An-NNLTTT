@startuml ModerationActivityDiagram
skinparam conditionStyle inside
title Activity Diagram: AI Tự Động Kiểm Duyệt Nội Dung (Moderation)

|Hệ Thống Lập Lịch (Job Scheduler)|
start
:Chạy ModerationJobScheduler mỗi 30s;
:Truy vấn danh sách ModerationJob (PENDING) ;

while (Còn Job chưa xử lý?) is (Có)
  :Lấy 1 ModerationJob & cập nhật trạng thái PROCESSING;
  
  if (Target Type) then (COMMENT)
    |Tương tác Bình luận (Comment)|
    if (Comment tồn tại và có text?) then (Có)
      :Gửi nội dung đến OpenAI API;
      if (Kết quả duyệt là BLOCK?) then (Có)
        :Gửi thông báo vi phạm;
        :Xóa Comment khỏi DB;
      endif
    endif
    
  else (POST)
    |Tương tác Bài viết (Post)|
    if (Post tồn tại?) then (Có)
      :Khởi tạo cờ reject = false;
      if (Có nội dung chữ?) then (Có)
        :Gửi text đến OpenAI API & lưu DB;
        if (Mức độ là BLOCK?) then (Có)
          :reject = true;
        endif
      endif
      
      while (Còn Media & reject == false) is (Còn)
        if (Loại Media?) then (IMAGE)
          :Gửi Image URL đến OpenAI & lưu DB;
        else (VIDEO)
          :Trích xuất Frames từ Video bằng FFmpeg;
          :Gửi URL từng Frame đến OpenAI API;
        endif
        
        if (Kết quả trả về bị BLOCK?) then (Có)
           :reject = true;
        endif
      endwhile (Hết)
      
      if (Đánh giá chung) then (reject == true)
        :PostStatus = REJECTED;
      elseif (Bị nghi ngờ/REVIEW) then (Có)
        :PostStatus = UNDER_REVIEW;
      else (An toàn)
        :PostStatus = PUBLISHED;
      endif
      
      :Cập nhật PostStatus vào Database;
      if (PostStatus != PUBLISHED) then (Có)
        :Thông báo cho tác giả quá trình kiểm duyệt;
      endif
    endif
  endif
  
  |Hệ Thống Lập Lịch (Job Scheduler)|
  :Đánh dấu Job hoàn tất (DONE);
endwhile (Hết)

stop
@enduml
