@startuml
actor User as U
boundary "CreatePostComponent" as FE
control "PostController" as Ctrl
control "S3Controller" as S3Ctrl
participant "PostService" as Svc
participant "S3Service" as S3Svc
participant "EntityManager" as EM
participant "PostMapper" as Mapper
database "PostRepository" as Repo
database "ModerationJobRepository" as ModRepo
database "UserRepository" as UserRepo

U -> FE: Nhập nội dung và chọn ảnh/video
U -> FE: Nhấn nút đăng
FE -> S3Ctrl: generatePresignedUrl(request)
activate S3Ctrl

S3Ctrl -> S3Svc: generatePresignedUrl(request)
activate S3Svc
S3Svc --> S3Ctrl: presignedUrlResponse
S3Ctrl --> FE: apiResponse (success, presignedUrlResponse)

FE -> Ctrl: createPost(postCreationRequest, currentUser)
Ctrl -> Svc: createPost(userId, postCreationRequest)
activate Svc

Svc -> UserRepo: findById(userId)
activate UserRepo
UserRepo --> Svc: user (hoặc throw USER_NOT_FOUND)

Svc -> Mapper: toPost(postCreationRequest, user)
activate Mapper
Mapper --> Svc: post (status=PENDING)

loop Mỗi media trong request
    Svc -> S3Svc: getContentTypeFromS3Url(url)
    S3Svc --> Svc: contentType

    alt contentType không đúng định dạng
        Svc --> Ctrl: throw INVALID_INPUT_DATA
        Ctrl --> FE: apiResponse (failed)
        FE --> U: Báo lỗi không đúng định dạng file
    else Định dạng hợp lệ
        Svc -> Svc: Thêm media vào danh sách PostMedia
    end
end

Svc -> Repo: saveAndFlush(post)
activate Repo

Svc -> EM: refresh(post)
activate EM

Svc -> ModRepo: save(moderationJob)
activate ModRepo

Svc -> Mapper: toPostResponse(post)
Mapper --> Svc: postResponse
Svc --> Ctrl: postResponse

Ctrl --> FE: apiResponse (success, postResponse)
FE --> U: Thông báo thành công và Tải lại trang chủ

@enduml